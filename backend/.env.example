# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=wpp_user
POSTGRES_PASSWORD=wpp_pass
POSTGRES_DB=wpp_autoflow
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://wpp_user:wpp_pass@localhost:5432/wpp_autoflow

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_super_secret_jwt_key_at_least_32_chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=change_me_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=7d

# ─── Evolution API ───────────────────────────────────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=evolution_secret_key
# Instância 1 — Shelby (Vendedor Principal) — obrigatório
EVOLUTION_INSTANCE_SHELBY_NAME=shelby
# Instância 2 — Moritz (Vendedor) — opcional
EVOLUTION_INSTANCE_MORITZ_NAME=
# Instância 3 — Cobrador (Cobrança de devedores) — opcional
EVOLUTION_INSTANCE_COBRADOR_NAME=
# Instância 4 — Prospectador (Leads de baixa credibilidade / novos usuários) — opcional
EVOLUTION_INSTANCE_PROSPECTADOR_NAME=
EVOLUTION_WEBHOOK_SECRET=webhook_secret_change_me

# ─── OpenRouter (AI responses) ───────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_key_here

# ─── MinIO / S3 ──────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_secret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_secret
S3_BUCKET=wpp-autoflow-media
S3_PUBLIC_URL=http://localhost:9000/wpp-autoflow-media
# URL alcançável de dentro do container da Evolution API (ela roda em outro container Docker,
# onde "localhost" aponta para si mesma, não para o host). host.docker.internal já está
# mapeado no docker-compose (extra_hosts) e resolve para o host, onde a porta 9000 do MinIO está exposta.
S3_PUBLIC_URL_EVOLUTION=http://host.docker.internal:9000/wpp-autoflow-media

# ─── Parâmetros do Sistema (valores padrão; sobrescritos pelo banco) ──────────
PULSE_ATIVO=true
PULSE_INTERVALO_MINUTOS=5
PULSE_MAX_CONTATOS_POR_CICLO=5
PULSE_COOLDOWN_HORAS=24
BROADCAST_DELAY_ENTRE_ENVIOS_MS=3000
MAX_UPLOAD_TAMANHO_MB=50
FLUXO_DELAY_PADRAO_SEGUNDOS=3
