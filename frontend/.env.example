# URL base da API do backend (NestJS).
# Local: aponta pro backend rodando em localhost.
# Railway/produção: configure esta mesma variável no painel do serviço
# (Settings → Variables) apontando pra URL pública do backend deployado —
# este arquivo .env não é lido em produção, o Vite builda o valor no bundle.
VITE_API_URL=http://localhost:3000
